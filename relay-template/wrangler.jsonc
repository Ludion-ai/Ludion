{
  // Ludion fallback relay — one-click deploy template.
  // Deploy with the button in the README, or `wrangler deploy` from the CLI.
  // The two secrets (PROVIDER_API_KEY, RELAY_TOKEN) are declared in
  // .dev.vars.example, so the dashboard deploy flow prompts you for them.
  "name": "ludion-fallback-relay",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-03",

  // Sensible defaults so the common case needs no editing. Change them in the
  // deploy wizard only if they do not match your setup.
  "vars": {
    // Your provider's OpenAI-compatible base URL. The relay appends
    // "/chat/completions". Defaults to OpenAI; change it if your fallback
    // model's provider differs (the workspace shows the right value).
    "UPSTREAM_BASE_URL": "https://api.openai.com/v1",
    // Comma-separated browser origins allowed to call this relay. No trailing
    // slash, never "*". Defaults to the Ludion playground so the workspace's
    // paste-back verify works on first deploy. Add your own app origin for
    // production. This is defense-in-depth, not the auth boundary.
    "ALLOWED_ORIGINS": "https://ludion.ai"
  },

  // Native Workers rate limiting. No resource creation needed, so it stays a
  // one-click deploy. The relay counts per client IP and returns 429 over the
  // cap, so a leaked token cannot drain your provider budget. period accepts
  // only 10 or 60 seconds; adjust limit to taste, or remove this block to
  // disable.
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 60, "period": 60 }
    }
  ]
}
