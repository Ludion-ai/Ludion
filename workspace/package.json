{
  "name": "ludion-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Ludion Workspace 2a: GitHub-auth + non-secret config persistence (Cloudflare Pages Functions / Worker)",
  "exports": {
    "./handler": {
      "types": "./src/handler.ts",
      "default": "./src/handler.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./session": {
      "types": "./src/session.ts",
      "default": "./src/session.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260612.1",
    "typescript": "5.9.3",
    "vitest": "4.1.8",
    "wrangler": "4.86.0"
  }
}
